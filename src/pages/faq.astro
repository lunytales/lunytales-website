---
import FaqSection from "../components/FaqSection.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { getStrings } from "../i18n";
import { createContactMailto } from "../lib/contact";
import { createSeo } from "../lib/seo";
import { createFaqStructuredData } from "../lib/structured-data";

const lang = "es" as const;
const strings = getStrings(lang);
const contactMailto = createContactMailto(strings.footer.email, lang);
const seo = createSeo({
  page: "faq",
  meta: {
    title: "Preguntas frecuentes | Luny Tales",
    description: "Respuestas sobre compra, acceso y uso de Luny Tales para familias.",
    ogTitle: "Preguntas frecuentes | Luny Tales",
    ogDescription: "Respuestas sobre compra, acceso y uso de Luny Tales para familias.",
    twitterTitle: "Preguntas frecuentes | Luny Tales",
    twitterDescription: "Respuestas sobre compra, acceso y uso de Luny Tales para familias.",
  },
  baseHref: import.meta.env.BASE_URL,
});
const structuredData = createFaqStructuredData({
  lang,
  pageUrl: seo.canonical,
  items: strings.faq.items,
});

const mascotImageSources = {
  src: "assets/img/mascota-768.webp",
  srcset: "assets/img/mascota-512.webp 512w, assets/img/mascota-768.webp 768w, assets/img/mascota-1024.webp 1024w",
};
---
<SiteLayout lang={lang} seo={seo} structuredData={structuredData} routeKey="faq" navVariant="legal" footerVariant="legal">
  <header class="hero-luny hero-luny--grad faq-hero">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <h1 class="hero-title mb-3">{strings.faq.title}</h1>
          <p class="hero-subtitle faq-hero__lead">{strings.faq.heroLead}</p>
        </div>

        <div class="col-lg-5 text-center text-lg-end">
          <img
            src={mascotImageSources.src}
            srcset={mascotImageSources.srcset}
            sizes="(max-width: 768px) 58vw, (max-width: 1199px) 40vw, 360px"
            alt={strings.hero.mascotAlt}
            width="1024"
            height="1024"
            class="hero-mascota faq-hero__mascot"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          >
        </div>
      </div>
    </div>
  </header>

  <FaqSection lang={lang} />

  <section class="py-4">
    <div class="container">
      <div class="faq-help text-center">
        <h2 class="h5 fw-bold mb-2">{strings.faq.helpTitle}</h2>
        <p class="mb-3">{strings.faq.helpText}</p>
        <a class="btn btn-primary btn-pill btn-luny px-4" href={contactMailto}>{strings.footer.email}</a>
      </div>
    </div>
  </section>
</SiteLayout>
