---
import HomePage from "../components/HomePage.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { createSeo } from "../lib/seo";
import { createFaqStructuredData, createHomeStructuredData } from "../lib/structured-data";
import { getStrings } from "../i18n";

const lang = "es" as const;
const strings = getStrings(lang);
const seo = createSeo({
  page: "home",
  meta: {
    title: strings.meta.title,
    description: strings.meta.description,
    ogTitle: strings.meta.ogTitle,
    ogDescription: strings.meta.ogDescription,
    twitterTitle: strings.meta.twitterTitle,
    twitterDescription: strings.meta.twitterDescription,
  },
  baseHref: import.meta.env.BASE_URL,
});
const homeStructuredData = createHomeStructuredData({
  lang,
  pageUrl: seo.canonical,
  description: strings.meta.description,
});
const faqStructuredData = createFaqStructuredData({
  lang,
  pageUrl: seo.canonical,
  items: strings.faq.items,
});
const structuredData = [homeStructuredData, faqStructuredData];
---
<SiteLayout
  lang={lang}
  seo={seo}
  structuredData={structuredData}
  routeKey="home"
  navVariant="home"
  footerVariant="home"
>
  <HomePage lang={lang} />
</SiteLayout>
