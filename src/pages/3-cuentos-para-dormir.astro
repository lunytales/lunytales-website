---
import SiteLayout from "../layouts/SiteLayout.astro";
import { createSeo } from "../lib/seo";
import { createHomeStructuredData } from "../lib/structured-data";
import StoriesCards from "../components/StoriesCards.astro";
import { SITE_CONFIG, toHref } from "../config/site";

const lang = "es" as const;
const title = "3 Cuentos para Dormir Niños | Luny Tales";
const description = "Cuentos cortos para dormir que ayudan a los niños a relajarse antes de dormir.";
const canonical = "https://lunytales.com/3-cuentos-para-dormir";
const canonicalEn = "https://lunytales.com/en/3-minute-bedtime-stories";

const seoBase = createSeo({
  page: "home",
  meta: {
    title,
    description,
    ogTitle: title,
    ogDescription: description,
    twitterTitle: title,
    twitterDescription: description,
  },
  baseHref: import.meta.env.BASE_URL,
});

const seo = {
  ...seoBase,
  canonical,
  alternates: [
    { hreflang: "es", href: canonical },
    { hreflang: "en", href: canonicalEn },
    { hreflang: "x-default", href: canonical },
  ],
  og: {
    ...seoBase.og,
    url: canonical,
  },
};

const structuredData = createHomeStructuredData({
  lang,
  pageUrl: canonical,
  description,
});
const homeHref = toHref(SITE_CONFIG.paths.home);
---
<SiteLayout lang={lang} seo={seo} structuredData={structuredData} routeKey="bedtimeStories" navVariant="home" footerVariant="home">
  <section class="py-5" id="a-dormir-3-cuentos">
    <div class="container">
      <h1 class="fw-bold mb-3">3 Cuentos para Dormir Niños</h1>
      <p class="mb-4">Cuentos cortos para dormir que ayudan a los niños a relajarse antes de acostarse.</p>

      <StoriesCards lang={lang} showHeader={false} />

      <p class="mt-4 mb-0">
        Estos tres cuentos cortos para dormir ayudan a los niños a relajarse antes de acostarse. Cada historia
        transmite valores como la empatía, la responsabilidad y la perseverancia, mientras crea un momento tranquilo
        entre padres e hijos al final del día.
      </p>

      <div class="mt-4 d-flex flex-column flex-lg-row gap-3 align-items-start cta-stack" id="comprar">
        <a class="btn btn-primary btn-pill btn-luny px-4" href={homeHref}>
          Escucha los cuentos completos con Luny Tales
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
