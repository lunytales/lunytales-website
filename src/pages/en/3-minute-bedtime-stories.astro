---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { createSeo } from "../../lib/seo";
import { createHomeStructuredData } from "../../lib/structured-data";
import { getStrings } from "../../i18n";
import StoriesCards from "../../components/StoriesCards.astro";
import { SITE_CONFIG, toHref } from "../../config/site";

const lang = "en" as const;
const strings = getStrings(lang);
const title = "3 Minute Bedtime Stories for Kids | Luny Tales";
const description = "Short calming bedtime stories that help children relax and fall asleep peacefully.";
const canonical = "https://lunytales.com/en/3-minute-bedtime-stories";
const canonicalEs = "https://lunytales.com/3-cuentos-para-dormir";

const seoBase = createSeo({
  page: "homeEn",
  meta: {
    title,
    description,
    ogTitle: title,
    ogDescription: description,
    twitterTitle: title,
    twitterDescription: description,
  },
  baseHref: import.meta.env.BASE_URL,
});

const seo = {
  ...seoBase,
  canonical,
  alternates: [
    { hreflang: "es", href: canonicalEs },
    { hreflang: "en", href: canonical },
    { hreflang: "x-default", href: canonicalEs },
  ],
  og: {
    ...seoBase.og,
    url: canonical,
  },
};

const structuredData = createHomeStructuredData({
  lang,
  pageUrl: canonical,
  description,
});
const homeEnHref = toHref(SITE_CONFIG.paths.homeEn);
---
<SiteLayout lang={lang} seo={seo} structuredData={structuredData} routeKey="bedtimeStories" navVariant="home" footerVariant="home">
  <section class="py-5" id="a-dormir-3-cuentos">
    <div class="container">
      <h1 class="fw-bold mb-3">3 Minute Bedtime Stories for Kids</h1>
      <p class="mb-4">Short bedtime stories that help children relax before sleep.</p>

      <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4">
        <div>
          <h2 class="fw-bold mb-1">{strings.stories.title}</h2>
          <p class="text-secondary mb-0">{strings.stories.subtitle}</p>
        </div>
      </div>

      <StoriesCards lang={lang} />

      <p class="mt-4 mb-0">
        These short bedtime stories help children relax before sleep. Each story encourages values like empathy,
        responsibility and perseverance, while creating a calm moment between parents and children at the end of the day.
      </p>

      <div class="mt-4 d-flex flex-column flex-lg-row gap-3 align-items-start cta-stack" id="comprar">
        <a class="btn btn-primary btn-pill btn-luny px-4" href={homeEnHref}>
          Listen to the full bedtime stories with Luny Tales
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
