---
const baseHref = import.meta.env.BASE_URL;
const siteUrl = Astro.site ?? new URL("https://lunytales.com");
const canonicalEs = new URL(baseHref, siteUrl).href;
const canonicalEn = new URL(`${baseHref}en/`, siteUrl).href;
const ogImagePng = new URL(`${baseHref}assets/img/og-lunytales.png`, siteUrl).href;
const ogImageWebp = new URL(`${baseHref}assets/img/og-lunytales.webp`, siteUrl).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <base href={baseHref} />
  <title>Luny Tales | English Version Coming Soon</title>
  <meta name="description" content="Luny Tales in English is coming soon. Explore bedtime stories and calming audio for kids." />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="canonical" href={canonicalEn} />
  <link rel="alternate" hreflang="es" href={canonicalEs} />
  <link rel="alternate" hreflang="en" href={canonicalEn} />
  <link rel="alternate" hreflang="x-default" href={canonicalEs} />

  <meta property="og:title" content="Luny Tales | English Version Coming Soon" />
  <meta property="og:description" content="Luny Tales in English is coming soon. Explore bedtime stories and calming audio for kids." />
  <meta property="og:image" content={ogImagePng} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image" content={ogImageWebp} />
  <meta property="og:image:type" content="image/webp" />
  <meta property="og:url" content={canonicalEn} />
  <meta property="og:type" content="website" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Luny Tales | English Version Coming Soon" />
  <meta name="twitter:description" content="Luny Tales in English is coming soon. Explore bedtime stories and calming audio for kids." />
  <meta name="twitter:image" content={ogImagePng} />

  <link rel="icon" href="favicon.ico" sizes="any" type="image/x-icon" />
  <link rel="icon" href="assets/favicon/favicon-16.png" sizes="16x16" type="image/png" />
  <link rel="icon" href="assets/favicon/favicon-32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="assets/favicon/favicon.svg" sizes="any" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="assets/favicon/apple-touch-icon-152.png" sizes="152x152" />
  <link rel="apple-touch-icon" href="assets/favicon/apple-touch-icon-167.png" sizes="167x167" />
  <link rel="apple-touch-icon" href="assets/favicon/apple-touch-icon.png" sizes="180x180" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="./styles.css" rel="stylesheet" />
</head>
<body class="bg-light luny">
  <a class="skip-link" href="#main">Skip to content</a>

  <nav class="navbar navbar-expand-lg navbar-luny sticky-top" aria-label="Main navigation">
    <div class="container">
      <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="./en/">
        <img src="assets/img/logo-horizontal.svg" alt="Luny Tales" width="178" height="28" class="nav-logo" />
      </a>
      <div class="navbar-nav ms-auto gap-2 align-items-lg-center">
        <a class="nav-link" href="./">Ver en Español</a>
      </div>
    </div>
  </nav>

  <main id="main" role="main">
    <header class="hero-luny hero-luny--grad py-5">
      <div class="container">
        <div class="row align-items-center g-4">
          <div class="col-lg-7">
            <img src="assets/img/logo2.svg" alt="A dormir en 3 cuentos" width="402" height="202" class="hero-logo mb-4" loading="eager" />
            <h1 class="hero-title mb-3">English version is coming soon.</h1>
            <p class="hero-subtitle mb-4">We are preparing Luny Tales in English while keeping the same bedtime experience.</p>
            <div class="d-flex flex-wrap gap-3">
              <a class="btn btn-primary btn-pill btn-luny px-4" href="./">Go to Spanish version</a>
            </div>
          </div>
          <div class="col-lg-5 text-center text-lg-end">
            <img
              src="assets/img/mascota.webp"
              alt="Luny mascot"
              width="1024"
              height="1024"
              class="hero-mascota"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </header>
  </main>

  <footer class="footer-luny">
    <div class="container position-relative">
      <div class="footer-bottom mt-0 pt-3">
        <div class="small">© <span id="y"></span> Luny Tales</div>
        <div class="footer-legal small">
          <a href="privacy">Privacidad</a>
          <span aria-hidden="true">|</span>
          <a href="terms">Términos</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script defer src="assets/js/utils.js"></script>
</body>
</html>
