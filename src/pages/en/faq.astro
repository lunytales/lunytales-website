---
import FaqSection from "../../components/FaqSection.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getStrings } from "../../i18n";
import { createContactMailto } from "../../lib/contact";
import { createSeo } from "../../lib/seo";
import { createFaqStructuredData } from "../../lib/structured-data";

const lang = "en" as const;
const strings = getStrings(lang);
const contactMailto = createContactMailto(strings.footer.email, lang);
const seo = createSeo({
  page: "faqEn",
  meta: {
    title: "Frequently Asked Questions | Luny Tales",
    description: "Answers about purchase, access, and usage for Luny Tales families.",
    ogTitle: "Frequently Asked Questions | Luny Tales",
    ogDescription: "Answers about purchase, access, and usage for Luny Tales families.",
    twitterTitle: "Frequently Asked Questions | Luny Tales",
    twitterDescription: "Answers about purchase, access, and usage for Luny Tales families.",
  },
  baseHref: import.meta.env.BASE_URL,
});
const structuredData = createFaqStructuredData({
  lang,
  pageUrl: seo.canonical,
  items: strings.faq.items,
});

const mascotImagePath = "assets/img/luny-faq.png";
---
<SiteLayout lang={lang} seo={seo} structuredData={structuredData} routeKey="faq" navVariant="legal" footerVariant="legal">
  <header class="hero-luny hero-luny--grad faq-hero">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <h1 class="hero-title faq-hero__title mb-3">
            <span class="faq-hero__title-main">Frequently Asked</span>{" "}
            <span class="faq-hero__title-accent">Questions</span>
          </h1>
          <p class="hero-subtitle faq-hero__lead">{strings.faq.heroLead}</p>
        </div>

        <div class="col-lg-5 text-center text-lg-end">
          <img
            src={mascotImagePath}
            alt={strings.hero.mascotAlt}
            width="1024"
            height="1024"
            class="hero-mascota faq-hero__mascot"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          >
        </div>
      </div>
    </div>
  </header>

  <FaqSection lang={lang} />

  <section class="py-4">
    <div class="container">
      <div class="faq-help text-center">
        <h2 class="h5 fw-bold mb-2">{strings.faq.helpTitle}</h2>
        <p class="mb-3">{strings.faq.helpText}</p>
        <a class="btn btn-primary btn-pill btn-luny px-4" href={contactMailto}>{strings.footer.email}</a>
      </div>
    </div>
  </section>
</SiteLayout>
