---
import { SITE_CONFIG, toHref } from "../config/site";
import { getStrings, type Language } from "../i18n";
import type { SeoMeta } from "../lib/seo";

interface Props {
  lang: Language;
  seo: SeoMeta;
  navVariant?: "home" | "legal";
  footerVariant?: "home" | "legal";
  legalNavLabel?: string;
}

const {
  lang,
  seo,
  navVariant = "home",
  footerVariant = navVariant === "legal" ? "legal" : "home",
  legalNavLabel = lang === "en" ? "Go to the main page" : "Ir a la página principal",
} = Astro.props;

const strings = getStrings(lang);
const baseHref = import.meta.env.BASE_URL;

const homeHref = toHref(SITE_CONFIG.paths.home);
const enHref = toHref(SITE_CONFIG.paths.homeEn);
const privacyHref = toHref(SITE_CONFIG.paths.privacy);
const termsHref = toHref(SITE_CONFIG.paths.terms);
const hotmartUrl = SITE_CONFIG.hotmartUrl;

const currentLangHomeHref = lang === "en" ? enHref : homeHref;
const brandHref = navVariant === "home" ? currentLangHomeHref : homeHref;
const footerLogoHref = footerVariant === "home" ? currentLangHomeHref : homeHref;

const primaryOgImage = seo.og.images[0];
const secondaryOgImage = seo.og.images[1];
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <base href={baseHref} />
  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />
  {seo.robots && <meta name="robots" content={seo.robots} />}
  <link rel="canonical" href={seo.canonical} />
  {seo.alternates.map((alternate) => (
    <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
  ))}

  <meta property="og:title" content={seo.og.title} />
  <meta property="og:description" content={seo.og.description} />
  {primaryOgImage && (
    <>
      <meta property="og:image" content={primaryOgImage.url} />
      <meta property="og:image:type" content={primaryOgImage.type} />
      {primaryOgImage.width && <meta property="og:image:width" content={String(primaryOgImage.width)} />}
      {primaryOgImage.height && <meta property="og:image:height" content={String(primaryOgImage.height)} />}
    </>
  )}
  {secondaryOgImage && (
    <>
      <meta property="og:image" content={secondaryOgImage.url} />
      <meta property="og:image:type" content={secondaryOgImage.type} />
    </>
  )}
  <meta property="og:url" content={seo.og.url} />
  <meta property="og:type" content={seo.og.type} />

  <meta name="twitter:card" content={seo.twitter.card} />
  <meta name="twitter:title" content={seo.twitter.title} />
  <meta name="twitter:description" content={seo.twitter.description} />
  <meta name="twitter:image" content={seo.twitter.image} />

  <link rel="icon" href="favicon.ico" sizes="any" type="image/x-icon">
  <link rel="icon" href="assets/favicon/favicon-16.png" sizes="16x16" type="image/png">
  <link rel="icon" href="assets/favicon/favicon-32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="assets/favicon/favicon.svg" sizes="any" type="image/svg+xml">
  <link rel="apple-touch-icon" href="assets/favicon/apple-touch-icon-152.png" sizes="152x152">
  <link rel="apple-touch-icon" href="assets/favicon/apple-touch-icon-167.png" sizes="167x167">
  <link rel="apple-touch-icon" href="assets/favicon/apple-touch-icon.png" sizes="180x180">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="styles.css" rel="stylesheet">
</head>

<body class="bg-light luny">
  <a class="skip-link" href="#main">{strings.a11y.skipToContent}</a>

  <nav class="navbar navbar-expand-lg navbar-luny sticky-top" aria-label={strings.a11y.mainNav}>
    <div class="container">
      <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href={brandHref}>
        <img src="assets/img/logo-horizontal.svg" alt="Luny Tales" width="178" height="28" class="nav-logo">
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#nav"
        aria-controls="nav"
        aria-expanded="false"
        aria-label={strings.a11y.openMenu}
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="nav">
        <div class="navbar-nav ms-auto gap-2 align-items-lg-center">
          {navVariant === "home" ? (
            <>
              <a class="nav-link" href="#incluye">{strings.nav.include}</a>
              <a class="nav-link" href="#como">{strings.nav.how}</a>

              <div class="d-flex align-items-center" role="group" aria-label={strings.a11y.languageSwitcher}>
                <a
                  class="nav-link px-1"
                  href={homeHref}
                  aria-label={strings.a11y.switchToEs}
                  aria-current={lang === "es" ? "page" : undefined}
                >
                  {strings.nav.languageEs}
                </a>
                <span class="nav-link px-0" aria-hidden="true">|</span>
                <a
                  class="nav-link px-1"
                  href={enHref}
                  aria-label={strings.a11y.switchToEn}
                  aria-current={lang === "en" ? "page" : undefined}
                >
                  {strings.nav.languageEn}
                </a>
              </div>

              <a
                class="btn btn-primary btn-pill btn-luny px-4 nav-cta d-lg-none"
                href={hotmartUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={strings.nav.buyMenuAria}
              >
                {strings.nav.buyNow}
              </a>
            </>
          ) : (
            <a class="nav-link" href={homeHref}>{legalNavLabel}</a>
          )}
        </div>
      </div>
    </div>
  </nav>

  <main id="main" role="main">
    <slot />
  </main>

  <footer class="footer-luny">
    <div class="container position-relative">
      {footerVariant === "home" ? (
        <>
          <div class="row gy-4 align-items-start">
            <div class="col-lg-4">
              <a href={footerLogoHref} class="d-inline-flex align-items-center gap-2 text-decoration-none">
                <img src="assets/img/logo-horizontal.svg" alt="Luny Tales" height="28">
              </a>
              <p class="footer-tagline mt-3 mb-0">{strings.footer.tagline}</p>
            </div>

            <div class="col-6 col-lg-3">
              <div class="footer-title">{strings.footer.navTitle}</div>
              <ul class="list-unstyled footer-links mb-0">
                <li><a href="#incluye">{strings.footer.navInclude}</a></li>
                <li><a href="#como">{strings.footer.navHow}</a></li>
                <li><a href="#comprar">{strings.footer.navBuy}</a></li>
              </ul>
            </div>

            <div class="col-6 col-lg-5">
              <div class="footer-title">{strings.footer.contactTitle}</div>
              <span class="footer-email d-inline-block">{strings.footer.email}</span>

              <div class="mt-2">
                <a class="btn btn-primary btn-pill btn-luny px-4" href={strings.footer.emailHref}>
                  {strings.footer.emailButton}
                </a>
              </div>
            </div>
          </div>
        </>
      ) : (
        <>
          <div class="row gy-4 align-items-start">
            <div class="col-lg-6">
              <a href={footerLogoHref} class="d-inline-flex align-items-center gap-2 text-decoration-none">
                <img src="assets/img/logo-horizontal.svg" alt="Luny Tales" height="28">
              </a>
              <p class="footer-tagline mt-3 mb-0">{strings.footer.tagline}</p>
            </div>

            <div class="col-lg-6">
              <div class="footer-title">{strings.footer.legalTitle}</div>
              <div class="footer-legal footer-legal-inline">
                <a href={privacyHref}>{strings.footer.legalPrivacy}</a>
                <span aria-hidden="true">|</span>
                <a href={termsHref}>{strings.footer.legalTerms}</a>
                <span aria-hidden="true">|</span>
                <button type="button" class="cookie-pref-link" id="cookiePrefs">{strings.footer.legalCookies}</button>
              </div>
            </div>
          </div>
        </>
      )}

      <img
        src="assets/img/mascota.webp"
        alt={strings.footer.mascotAlt}
        width="1024"
        height="1024"
        class="footer-mascota d-none d-lg-block"
        loading="lazy"
      >

      <div class="footer-bottom mt-4 pt-3">
        <div class="small">© <span id="y"></span> Luny Tales</div>
        {footerVariant === "home" && (
          <div class="footer-legal small">
            <a href={privacyHref}>{strings.footer.legalPrivacy}</a>
            <span aria-hidden="true">|</span>
            <a href={termsHref}>{strings.footer.legalTerms}</a>
            <span aria-hidden="true">|</span>
            <button type="button" class="cookie-pref-link" id="cookiePrefs">{strings.footer.legalCookies}</button>
          </div>
        )}
      </div>
    </div>
  </footer>

  <div
    class="cookie-banner"
    id="cookieBanner"
    hidden
    role="region"
    aria-label={strings.a11y.cookieRegion}
    aria-live="polite"
  >
    <div class="cookie-banner__inner">
      <p class="cookie-banner__text">
        {strings.cookie.textLine1}<br class="cookie-banner__br">
        {strings.cookie.textLine2}
      </p>
      <div class="cookie-banner__actions">
        <button type="button" class="btn btn-primary btn-pill btn-luny cookie-banner__btn" id="cookieAccept">
          {strings.cookie.accept}
        </button>
        <button type="button" class="btn btn-outline-mint btn-pill btn-luny cookie-banner__btn" id="cookieReject">
          {strings.cookie.reject}
        </button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ trackingGateEnabled: SITE_CONFIG.trackingGate }}>
    window.__LUNY_CONFIG = window.__LUNY_CONFIG || {};
    window.__LUNY_CONFIG.flags = Object.assign({}, window.__LUNY_CONFIG.flags, {
      trackingGate: trackingGateEnabled,
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script defer src="assets/js/utils.js"></script>
  <script defer src="assets/js/nav.js"></script>
  <script defer src="assets/js/consent.js"></script>
</body>
</html>
