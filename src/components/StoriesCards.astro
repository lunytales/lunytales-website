---
import { getStrings, type Language } from "../i18n";

interface Props {
  lang: Language;
  showHeader?: boolean;
}

const { lang, showHeader = true } = Astro.props;
const strings = getStrings(lang);

const storyImageSources = [
  {
    defaultSrc: "assets/img/timo-640.webp",
    srcSet: "assets/img/timo-384.webp 384w, assets/img/timo-640.webp 640w, assets/img/timo.webp 1100w",
  },
  {
    defaultSrc: "assets/img/galen-640.webp",
    srcSet: "assets/img/galen-384.webp 384w, assets/img/galen-640.webp 640w, assets/img/galen.webp 1100w",
  },
  {
    defaultSrc: "assets/img/lira-640.webp",
    srcSet: "assets/img/lira-384.webp 384w, assets/img/lira-640.webp 640w, assets/img/lira.webp 1100w",
  },
] as const;

const storyImageSizes = "(max-width: 575.98px) calc(100vw - 2rem), (max-width: 991.98px) calc(50vw - 1.75rem), 360px";
---
{showHeader && (
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4">
    <div>
      <h2 class="fw-bold mb-1">{strings.stories.title}</h2>
      <p class="text-secondary mb-0">{strings.stories.subtitle}</p>
    </div>
  </div>
)}

<div class="row g-3">
  {strings.stories.items.map((story, index) => (
    <div class="col-lg-4">
      <article class="story-vertical card h-100 shadow-sm">
        <div class="story-vertical__media">
          <img
            src={storyImageSources[index]?.defaultSrc ?? storyImageSources[0].defaultSrc}
            srcset={storyImageSources[index]?.srcSet ?? storyImageSources[0].srcSet}
            sizes={storyImageSizes}
            alt={story.imageAlt}
            width="1100"
            height="1100"
            class="story-vertical__img"
            loading="lazy"
            decoding="async"
          >
        </div>
        <div class="story-vertical__body">
          <h3 class="story-title">{story.title}</h3>
          <p class="story-desc">{story.description}</p>
        </div>
      </article>
    </div>
  ))}
</div>
