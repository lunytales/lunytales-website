---
import { getStrings, type Language } from "../i18n";

interface Props {
  lang: Language;
  showHeader?: boolean;
}

const { lang, showHeader = true } = Astro.props;
const strings = getStrings(lang);
const accordionId = `faq-accordion-${lang}`;
const faqToneClasses = [
  "faq-item--mint",
  "faq-item--lila",
  "faq-item--durazno",
  "faq-item--cielo",
] as const;
const faqIconPaths = [
  "libro.webp",
  "audio.webp",
  "policy-sin-registros.webp",
  "policy-privacidad-total.webp",
  "luna.webp",
  "audio.webp",
  "policy-voz-segura.webp",
  "libro.webp",
] as const;
---
<section class="py-5 bg-white border-top" id="faq">
  <div class="container">
    {showHeader && (
      <div class="mb-4">
        <h2 class="fw-bold mb-1">{strings.faq.title}</h2>
        <p class="text-secondary mb-0">{strings.faq.subtitle}</p>
      </div>
    )}

    <div class="accordion faq-accordion" id={accordionId}>
      {strings.faq.items.map((item, index) => {
        const headingId = `${accordionId}-heading-${index}`;
        const collapseId = `${accordionId}-collapse-${index}`;
        const isFirst = index === 0;
        const toneClass = faqToneClasses[index % faqToneClasses.length] ?? faqToneClasses[0];
        const iconPath = faqIconPaths[index % faqIconPaths.length] ?? faqIconPaths[0];

        return (
          <article class={`accordion-item faq-item ${toneClass}`.trim()}>
            <h3 class="accordion-header" id={headingId}>
              <button
                class={`accordion-button faq-question ${isFirst ? "" : "collapsed"}`.trim()}
                type="button"
                data-bs-toggle="collapse"
                data-bs-target={`#${collapseId}`}
                aria-expanded={isFirst ? "true" : "false"}
                aria-controls={collapseId}
              >
                <img class="faq-question__icon" src={`assets/icons/${iconPath}`} alt="" loading="lazy" decoding="async">
                <span class="faq-question__text">{item.question}</span>
                <span class="faq-toggle-icon" aria-hidden="true"></span>
              </button>
            </h3>

            <div
              id={collapseId}
              class={`accordion-collapse collapse ${isFirst ? "show" : ""}`.trim()}
              aria-labelledby={headingId}
              data-bs-parent={`#${accordionId}`}
            >
              <div class="accordion-body faq-answer">
                <p class="mb-0">{item.answer}</p>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
