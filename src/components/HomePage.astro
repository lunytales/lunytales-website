---
import { SITE_CONFIG, toHref } from "../config/site";
import { getStrings, type Language } from "../i18n";
import StoriesCards from "./StoriesCards.astro";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const strings = getStrings(lang);

const includeCardClasses = [
  "incluye-card--1",
  "incluye-card--2",
  "incluye-card--3",
  "incluye-card--4",
] as const;

const howPillClasses = ["how-pill--lila", "how-pill--mint", "how-pill--durazno"] as const;
const howIconPaths = ["libro.webp", "audio.webp", "luna.webp"] as const;

const hotmartUrl = lang === "en" ? SITE_CONFIG.hotmartUrlEn : SITE_CONFIG.hotmartUrlEs;
const demoPdfPath = lang === "en" ? SITE_CONFIG.paths.demoPdfEn : SITE_CONFIG.paths.demoPdf;
const currentLangHomePath = lang === "en" ? SITE_CONFIG.paths.homeEn : SITE_CONFIG.paths.home;
const includeSectionHref = `${toHref(currentLangHomePath)}#incluye`;
const mascotImageSrc = "assets/img/mascota-luny-768.webp";
const mascotImageSrcSet =
  "assets/img/mascota-luny-512.webp 512w, assets/img/mascota-luny-768.webp 768w, assets/img/mascota-luny-1024.webp 1024w";
const mascotImageSizes = "(max-width: 575.98px) 78vw, (max-width: 991.98px) 84vw, 560px";
---
<header class="hero-luny hero-luny--grad">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <img
          src={strings.hero.titleImageSrc}
          alt={strings.hero.logoAlt}
          width="402"
          height="202"
          class="hero-logo mb-4"
          loading="eager"
          decoding="async"
        >

        <h1 class="hero-title mb-3">{strings.hero.title}</h1>

        <p class="hero-subtitle mb-4">{strings.hero.subtitle}</p>

        <div class="d-flex flex-wrap gap-3" id="comprar">
          <a
            class="btn btn-primary btn-pill btn-luny px-4"
            href={hotmartUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={strings.hero.buyAria}
          >
            {strings.hero.buyNow}
          </a>
          <a class="btn btn-outline-mint btn-pill btn-luny px-4" href={includeSectionHref}>
            {strings.hero.includeCta}
          </a>
        </div>
      </div>

      <div class="col-lg-6 text-center text-lg-end">
        <img
          src={mascotImageSrc}
          srcset={mascotImageSrcSet}
          sizes={mascotImageSizes}
          alt={strings.hero.mascotAlt}
          width="1024"
          height="1024"
          class="hero-mascota"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        >
      </div>
    </div>
  </div>
</header>

<section class="py-5 bg-white border-top" id="incluye">
  <div class="container">
    <h2 class="fw-bold mb-4">{strings.includes.title}</h2>

    <div class="row g-3">
      {strings.includes.items.map((item, index) => (
        <div class="col-md-6 col-lg-3">
          <div class={`card h-100 incluye-card ${includeCardClasses[index] ?? ""}`}>
            <div class="card-body">
              <h3 class="fw-bold h6 m-0">{item.title}</h3>
              <div class="incluye-note small mt-1">{item.note}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-5" id="a-dormir-3-cuentos">
  <div class="container">
    <StoriesCards lang={lang} />

    <div class="mt-4 d-flex flex-column flex-lg-row gap-3 align-items-start cta-stack">
      <a
        class="btn btn-primary btn-pill btn-luny px-4"
        href={hotmartUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={strings.stories.buyAria}
      >
        {strings.stories.buyNow}
      </a>
      <a
        class="btn btn-outline-mint btn-pill btn-luny px-4"
        href={demoPdfPath}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={strings.stories.demoAria}
      >
        {strings.stories.demo}
      </a>
    </div>
  </div>
</section>

<section class="py-5" id="como">
  <div class="container">
    <h2 class="fw-bold mb-4">{strings.how.title}</h2>

    <div class="row g-3">
      {strings.how.items.map((item, index) => (
        <div class="col-lg-4">
          <div class={`how-pill ${howPillClasses[index] ?? howPillClasses[0]}`}>
            <div class="how-pill__text">
              <h3 class="how-pill__title">{item.title}</h3>
              <div class="how-pill__desc">{item.description}</div>
            </div>
            <img class="how-pill__icon" src={`assets/icons/${howIconPaths[index] ?? howIconPaths[0]}`} alt="" loading="lazy">
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

